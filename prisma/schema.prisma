generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Client {
  id                      String   @id @default(uuid())
  email                   String   @unique
  name                    String?
  passwordHash            String?  // Nullable if they sign up via Google
  googleId                String?  @unique
  planTier                String   @default("starter") // starter, pro, business
  role                    String   @default("client")  // client, admin
  electricityProviderId   String?
  waterProviderId         String?
  applianceCount          Int      @default(0)
  consentGiven            Boolean  @default(true)
  onboardingComplete      Boolean  @default(false)
  emailAlertsEnabled      Boolean  @default(true)
  planExpiry              DateTime?
  subscriptionId          String?

  scanCount               Int      @default(0)
  lastScanReset           DateTime @default(now())
  
  readings    UtilityReading[]
  reports     AIReport[]
  alerts      Alert[]
  appliances  Appliance[]
  properties  Property[]
  dailyReadings DailyMeterReading[]
  lpgReadings LPGReading[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Property {
  id                    String   @id @default(uuid())
  clientId              String
  client                Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  name                  String                // e.g. "Main Home", "Condo Unit 4B"
  address               String?
  electricityProviderId String?
  waterProviderId       String?
  isDefault             Boolean  @default(false)

  readings              UtilityReading[]
  appliances            Appliance[]
  reports               AIReport[]
  lpgReadings           LPGReading[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model UtilityProvider {
  id             String   @id @default(uuid())
  name           String
  type           String   // electricity, water
  region         String?
  baseRate       Float    @default(0)
  benchmarkAvg   Float    @default(0)
  logoUrl        String?  // URL to the provider's official logo (admin-managed)
  website        String?  // Official website URL
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model UtilityReading {
  id                   String   @id @default(uuid())
  
  clientId             String
  client               Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  propertyId           String?
  property             Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  kwhUsed              Float    @default(0)
  m3Used               Float    @default(0)
  billAmountElectric   Float    @default(0)
  billAmountWater      Float    @default(0)
  readingDate          String

  // Unbundled charges — populated by AI bill parser (null if manual entry)
  generationCharge     Float?
  transmissionCharge   Float?
  systemLoss           Float?
  distributionCharge   Float?
  subsidies            Float?
  governmentTax        Float?
  vat                  Float?
  otherCharges         Float?

  // Derived & metadata
  effectiveRate        Float?   // bill / kWh
  sourceType           String   @default("manual") // manual, ai_scan
  providerDetected     String?
  billingPeriod        String?

  submittedAt          DateTime @default(now())
}

model AIReport {
  id                 String   @id @default(uuid())
  
  clientId           String
  client             Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  propertyId         String?
  property           Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  summary            String
  recommendations    String?
  estimatedSavings   Float    @default(0)
  providerContext    String?
  pdfUrl             String?  // Pro: link to stored PDF export

  generatedAt        DateTime @default(now())
}

model Alert {
  id           String   @id @default(uuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  title        String
  message      String
  severity     String   @default("info") // info, warning, critical
  isRead       Boolean  @default(false)
  
  createdAt    DateTime @default(now())
}

model Appliance {
  id             String   @id @default(uuid())
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  propertyId     String?
  property       Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  name           String
  category       String   @default("other")
  brand          String?
  model          String?
  year           Int?
  wattage        Float?
  hoursPerDay    Float?
  energyRating   String   @default("not-rated")
  notes          String?
  quantity       Int      @default(1)
  
  createdAt      DateTime @default(now())
}

model VerificationToken {
  id        String   @id @default(uuid())
  email     String
  token     String   // 6-digit OTP
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model DailyMeterReading {
  id          String   @id @default(uuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  meterValue  Float
  date        String
  kwhDelta    Float?
  createdAt   DateTime @default(now())
}

// ── Appliance Catalog (Phase 0 Baseline) ───────────────────────────

enum ApplianceCategory {
  AC
  Fridge
  Heater
  Pump
  WaterFixture // New: for leak tracking
  GasStove     // New: for LPG tracking
  Other
}

model ApplianceCatalog {
  id                 String            @id @default(uuid())
  brand              String
  modelNumber        String            @unique
  category           ApplianceCategory
  wattage            Float
  coolingCapacityKjH Float?
  eerRating          Float?
  estimatedPricePhp  Float?
  sourceUrl          String?
  modelYear          Int?
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([category, brand])
}

model LPGReading {
  id             String   @id @default(uuid())
  
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  propertyId     String?
  property       Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  tankSizeKg     Float    // e.g. 11kg
  costPhp        Float    // e.g. 1100
  brand          String?  // e.g. Solane, Petronas
  replacementDate String  // YYYY-MM-DD
  isEmpty        Boolean  @default(false)
  
  createdAt      DateTime @default(now())
}
