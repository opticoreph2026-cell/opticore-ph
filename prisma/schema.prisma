generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  // Always file: for prisma validate / prisma generate.
  // Runtime: db.js overrides to LibSQL adapter when TURSO_DATABASE_URL is set.
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  INDUSTRIAL
}

enum AuthProviderType {
  PASSWORD       // traditional email/password
  GOOGLE
  APPLE          // future
  FACEBOOK       // future
}

enum ScanSource {
  MANUAL
  AI_SCAN
  IMPORT
}

enum ProviderType {
  PRIVATE_DU   // Private Distribution Utility (Meralco, VECO, Davao Light)
  COOPERATIVE  // Electric Cooperative (BENECO, BATELEC, FLECO, etc.)
  SUB_METER    // Sub-metering operator
}

// ── Models ────────────────────────────────────────────────────────────────────

model AuthProvider {
  id            String           @id @default(cuid())
  clientId      String
  provider      AuthProviderType
  providerId    String           // Google's "sub" claim, Apple's user ID, etc.
  email         String           // email reported by provider (may differ from primary)
  emailVerified Boolean          @default(false)
  metadata      String?          // Store as String since SQLite doesn't have native JSON
  createdAt     DateTime         @default(now())
  lastUsedAt    DateTime         @default(now())
  
  client        Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerId])
  @@index([clientId])
  @@index([email])
}

model Client {
  id                    String    @id @default(uuid())
  email                 String    @unique
  name                  String?
  passwordHash          String?   // Nullable if they sign up via Google
  emailVerified         DateTime?
  googleId              String?   @unique
  planTier              String    @default("starter") // starter, pro, negosyo
  avatar                String?   // Profile picture URL (Google or custom)
  role                  String    @default("client")  // client, admin
  electricityProviderId String?
  waterProviderId       String?
  consentGiven          Boolean   @default(true)
  onboardingComplete    Boolean   @default(false)
  emailAlertsEnabled    Boolean   @default(true)
  planExpiry            DateTime?
  subscriptionId        String?

  totalTokensUsed Int       @default(0)
  lastLoginAt     DateTime?
  lastSignedInAt  DateTime? // Updates on every successful sign-in
  lastScanReset   DateTime  @default(now())
  locale          String    @default("en") // e.g. "en", "tl"

  readings      UtilityReading[]
  reports       AIReport[]
  alerts        Alert[]
  appliances    Appliance[]
  properties    Property[]
  transactions  Transaction[]
  refreshTokens RefreshToken[]
  authProviders AuthProvider[]
  signInEvents  SignInEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SignInEvent {
  id          String           @id @default(cuid())
  clientId    String
  provider    AuthProviderType
  ipAddress   String?
  userAgent   String?
  success     Boolean
  failReason  String?
  createdAt   DateTime         @default(now())
  
  client      Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  @@index([clientId, createdAt(sort: Desc)])
}

model Property {
  id       String @id @default(uuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  name                  String  // e.g. "Main Home", "Condo Unit 4B"
  address               String?
  electricityProviderId String?
  waterProviderId       String?
  isDefault             Boolean @default(false)

  readings   UtilityReading[]
  appliances Appliance[]
  reports    AIReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

model UtilityProvider {
  id   String @id @default(uuid())
  code String @unique // e.g. MERALCO, VECO, DAVAOLIGHT

  name         String
  type         ProviderType @default(PRIVATE_DU)
  region       String?
  isSupported  Boolean      @default(false)   // true = live parsing supported
  bestEffortOnly Boolean    @default(true)    // false = full unbundled parse guaranteed
  parserVersion  String     @default("v1")

  // Rates stored as integer rate units (₱/kWh × 10,000)
  baseRate     Int     @default(0)
  benchmarkAvg Int     @default(0)

  logoUrl  String? // Official logo URL (admin-managed)
  website  String? // Official website URL

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([type, isSupported])
}

model UtilityReading {
  id String @id @default(uuid())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // Primary consumption data
  kwhUsed   Int @default(0) // stored as integer (whole Wh? No — keep kWh×100 = centikWh? Actually kWh can stay as Int rounded)
                              // Decision: store as Int (rounded kWh, e.g. 200 = 200 kWh). Fractional kWh not needed for billing.

  // Money fields — all stored as Int (centavos, ₱ × 100)
  billAmountElectric Int @default(0)

  // Unbundled charges as JSON blob (flexible, avoids column sprawl)
  // Structure: { generation, transmission, systemLoss, distribution, subsidies, governmentTax, vat, otherCharges }
  // All values in centavos (Int).
  unbundledCharges String? // JSON blob

  // Rate — stored as rate units (₱/kWh × 10,000). e.g. ₱11.4250 → 114250
  effectiveRate Int?

  // Billing period
  readingDate      DateTime @default(now())
  billingPeriodStart DateTime?
  billingPeriodEnd   DateTime?

  // Metadata
  sourceType       ScanSource @default(MANUAL)
  confidence       Float      @default(1.0) // AI scan confidence (0.0–1.0)
  providerDetected String?
  billingPeriod    String?                  // Legacy: human-readable period label

  submittedAt DateTime @default(now())

  @@index([clientId, readingDate(sort: Desc)])
  @@index([propertyId, readingDate(sort: Desc)])
  @@index([clientId, billingPeriodStart])
}

model AIReport {
  id String @id @default(uuid())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  summary          String
  narrativeSummary String?
  recommendations  String?

  // Money fields — centavos (Int)
  estimatedSavings Int @default(0)
  potentialSavings Int?

  providerContext String?
  pdfUrl          String? // Pro: link to stored PDF export

  generatedAt DateTime @default(now())

  @@index([clientId, generatedAt(sort: Desc)])
  @@index([propertyId])
}

model Alert {
  id       String @id @default(uuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  title    String
  message  String
  severity String  @default("info")  // info, warning, critical
  type     String  @default("rate")  // ghost_load, water_leak, spike, rate
  isRead   Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([isRead])
  @@index([clientId, isRead])
}

model Appliance {
  id       String @id @default(uuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  name         String
  category     String @default("other")
  brand        String?
  model        String?
  year         Int?
  wattage      Int?   // whole watts (no fractional watt needed for billing)
  hoursPerDay  Float? // kept as Float: 8.5h is meaningful, not money
  energyRating String @default("not-rated")
  notes        String?
  quantity     Int    @default(1)

  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([propertyId])
}

model VerificationToken {
  id        String   @id @default(uuid())
  email     String
  token     String   // 6-digit OTP
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model Transaction {
  id       String @id @default(uuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Money — centavos (Int)
  amount      Int    @default(0)
  currency    String @default("PHP")
  planTier    String // starter, pro, negosyo
  type        String @default("payment") // payment, manual_override
  referenceId String? // PayMongo session ID or Admin Note
  status      String @default("completed")

  createdAt DateTime @default(now())

  @@index([clientId, createdAt(sort: Desc)])
}

model RefreshToken {
  id       String @id @default(uuid())
  token    String @unique
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([clientId])
}

// ── Admin Notification System ─────────────────────────────────────────────────

model AdminNotification {
  id        String   @id @default(uuid())
  // Valid types: new_user | payment | ai_scan | report | system | ai_forecast | solar
  type      String
  title     String
  message   String
  meta      String?  // JSON blob: { clientId, clientName, email, plan, amount, ... }
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
