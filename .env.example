# OptiCore PH — Environment Variables Reference
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 64
JWT_SECRET=your-jwt-secret-min-64-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-64-chars
ADMIN_CRON_SECRET=your-cron-secret-random-string
BCRYPT_ROUNDS=12

# ── Cloudflare Turnstile (bot protection) ────────────────────────────────────
# Get keys at: https://dash.cloudflare.com/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# ── Database ──────────────────────────────────────────────────────────────────
# Keep DATABASE_URL as file: for prisma validate/generate.
# Runtime db.js uses TURSO_* for production (LibSQL adapter).
DATABASE_URL="file:./dev.db"
TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# ── AI ────────────────────────────────────────────────────────────────────────
# Google Gemini 2.5 Flash — https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key

# ── Gmail OAuth2 (for transactional email) ───────────────────────────────────
# Set up at: https://console.cloud.google.com/
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password  # Fallback SMTP (optional)
GMAIL_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground

# ── Google OAuth Sign-In (Phase 5) ───────────────────────────────────────────
# Same Google Cloud project as Gmail. Add callback to Authorized Redirect URIs:
# http://localhost:3000/api/auth/google/callback (dev)
# https://yourdomain.com/api/auth/google/callback (prod)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── PayMongo ─────────────────────────────────────────────────────────────────
# Get keys at: https://dashboard.paymongo.com/
PAYMONGO_SECRET_KEY=sk_test_your-secret-key
NEXT_PUBLIC_PAYMONGO_PUBLIC_KEY=pk_test_your-public-key
PAYMONGO_WEBHOOK_SECRET=whsk_your-webhook-secret

# ── Analytics ────────────────────────────────────────────────────────────────
# PostHog — https://app.posthog.com/
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to "true" to enable gated features in development
FEATURE_LPG_TRACKING=false
FEATURE_APPLIANCE_CATALOG=false
